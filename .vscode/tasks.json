{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "lint:tsc",
      "path": "sudoku-web",
      "problemMatcher": {
        "base": "$tsc",
        "fileLocation": ["relative", "${workspaceFolder}/sudoku-web"]
      },
      "label": "npm: lint:tsc - sudoku-web"
    },
    {
      "type": "npm",
      "script": "lint:tsc:watch",
      "path": "sudoku-web",
      "problemMatcher": {
        "base": "$tsc-watch",
        "fileLocation": ["relative", "${workspaceFolder}/sudoku-web"]
      },
      "label": "npm: lint:tsc:watch - sudoku-web",
      "detail": "tsc -b --watch",
      "isBackground": true
    },
    {
      "type": "npm",
      "script": "lint:eslint",
      "path": "sudoku-web",
      "problemMatcher": ["$eslint-stylish"],
      "label": "npm: lint:eslint - sudoku-web",
      "detail": "eslint src/** webpack.config.ts"
    }
  ]
}
