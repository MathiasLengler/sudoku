{
    "author": "Mathias Lengler <mathias@lengler.dev>",
    "name": "sudoku-web",
    "version": "0.2.0",
    "license": "MIT",
    "repository": "https://github.com/MathiasLengler/sudoku",
    "engines": {
        "node": "20"
    },
    "scripts": {
        "dev": "webpack serve --mode development",
        "dev:profiling": "webpack serve --mode production --env reactProfiling=true",
        "build": "webpack --mode production",
        "build:dev": "webpack --mode development",
        "build:debugSW": "webpack --mode development --env debugSW=true",
        "build:analyze": "webpack --mode production --env bundleAnalyzer=true",
        "lint": "npm run lint:tsc && npm run lint:eslint && npm run lint:prettier",
        "lint:tsc": "tsc",
        "lint:tsc:watch": "tsc --watch",
        "lint:eslint": "npm run lint:eslint:files -- --max-warnings 0",
        "lint:eslint:fix": "npm run lint:eslint:files -- --fix",
        "lint:eslint:files": "eslint src/** webpack.config.ts",
        "lint:prettier": "npm run lint:prettier:files -- --check",
        "lint:prettier:fix": "npm run lint:prettier:files -- --write",
        "lint:prettier:files": "prettier src/** res/**/*.{css,html} ../.github/**/*.yml webpack.config.ts",
        "serve": "npx serve -l 8080 -c ../serve.json dist",
        "bubblewrap:merge": "cd ../sudoku-bubblewrap && bubblewrap merge",
        "bubblewrap:update": "cd ../sudoku-bubblewrap && bubblewrap update",
        "bubblewrap:build": "cd ../sudoku-bubblewrap && bubblewrap build",
        "docker:build": "docker build -t sudoku-web .",
        "docker:run": "docker run -it --rm -p 8080:80 sudoku-web",
        "docker:dev": "npm run build && npm run docker:build && npm run docker:run"
    },
    "dependencies": {
        "@babel/runtime": "^7.24.7",
        "@emotion/react": "^11.11.4",
        "@emotion/styled": "^11.11.5",
        "@fontsource-variable/inconsolata": "^5.0.18",
        "@fontsource-variable/roboto-flex": "^5.0.15",
        "@hookform/resolvers": "^3.6.0",
        "@mui/icons-material": "^5.15.20",
        "@mui/lab": "^5.0.0-alpha.170",
        "@mui/material": "^5.15.20",
        "@mui/x-date-pickers": "^7.7.1",
        "@tanstack/react-query": "^5.45.1",
        "assert-never": "^1.2.1",
        "classnames": "^2.5.1",
        "comlink": "^4.4.1",
        "lodash": "^4.17.21",
        "notistack": "^3.0.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-error-boundary": "^4.0.13",
        "react-hook-form": "^7.52.0",
        "react-hook-form-mui": "^7.0.0",
        "react-resize-detector": "^11.0.1",
        "react-virtualized-auto-sizer": "^1.0.24",
        "react-window": "^1.8.10",
        "recoil": "^0.7.7",
        "workbox-window": "^7.1.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@babel/core": "^7.24.7",
        "@babel/preset-env": "^7.24.7",
        "@babel/preset-react": "^7.24.7",
        "@babel/preset-typescript": "^7.24.7",
        "@babel/register": "^7.24.6",
        "@bubblewrap/cli": "^1.21.0",
        "@pmmmwh/react-refresh-webpack-plugin": "^0.5.15",
        "@tsconfig/strictest": "^2.0.5",
        "@types/eslint__js": "^8.42.3",
        "@types/lodash": "^4.17.5",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@types/react-window": "^1.8.8",
        "@types/webpack-bundle-analyzer": "^4.7.0",
        "@wasm-tool/wasm-pack-plugin": "1.7.0",
        "babel-loader": "^9.1.3",
        "copy-webpack-plugin": "^12.0.2",
        "css-loader": "^7.1.2",
        "csstype": "^3.1.3",
        "eslint": "^8.56.0",
        "eslint-plugin-react": "^7.34.3",
        "eslint-plugin-react-hooks": "^4.6.2",
        "favicons": "^7.2.0",
        "favicons-webpack-plugin": "^6.0.1",
        "fork-ts-checker-webpack-plugin": "^9.0.2",
        "html-webpack-plugin": "^5.6.0",
        "prettier": "^3.3.2",
        "react-refresh": "^0.14.2",
        "style-loader": "^4.0.0",
        "type-fest": "^4.20.1",
        "typescript": "^5.5.2",
        "typescript-eslint": "^7.13.1",
        "webpack": "^5.92.1",
        "webpack-bundle-analyzer": "^4.10.2",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^5.0.4",
        "webpack-pwa-manifest": "^4.3.0",
        "workbox-webpack-plugin": "^7.1.0",
        "worker-plugin": "^5.0.1"
    },
    "overrides": {
        "@pmmmwh/react-refresh-webpack-plugin": {
            "webpack-dev-server": "^5.0.4"
        }
    }
}
