{
    "author": "Mathias Lengler <mathias@lengler.dev>",
    "name": "sudoku-web",
    "version": "0.2.0",
    "license": "MIT",
    "repository": "https://github.com/MathiasLengler/sudoku",
    "engines": {
        "node": "20"
    },
    "scripts": {
        "start": "webpack serve --mode development",
        "start:profiling": "webpack serve --mode production --env reactProfiling=true",
        "build": "webpack --mode production",
        "build:debugSW": "webpack --mode development --env debugSW=true",
        "build:analyze": "webpack --mode production --env bundleAnalyzer=true",
        "lint": "npm run lint:tsc && npm run lint:eslint && npm run lint:prettier",
        "lint:tsc": "tsc",
        "lint:eslint": "eslint src/** webpack.config.ts",
        "lint:prettier": "npm run lint:prettier:files -- --check",
        "lint:prettier:fix": "npm run lint:prettier:files -- --write",
        "lint:prettier:files": "prettier src/** res/**/*.{css,html} ../.github/**/*.yml webpack.config.ts",
        "serve": "npx serve -l 8080 -c ../serve.json dist",
        "bubblewrap:merge": "cd ../sudoku-bubblewrap && bubblewrap merge",
        "bubblewrap:update": "cd ../sudoku-bubblewrap && bubblewrap update",
        "bubblewrap:build": "cd ../sudoku-bubblewrap && bubblewrap build"
    },
    "dependencies": {
        "@babel/runtime": "^7.24.0",
        "@emotion/react": "^11.11.4",
        "@emotion/styled": "^11.11.0",
        "@fontsource-variable/inconsolata": "^5.0.17",
        "@fontsource-variable/roboto-flex": "^5.0.13",
        "@hookform/resolvers": "^3.3.4",
        "@mui/icons-material": "^5.15.12",
        "@mui/lab": "^5.0.0-alpha.167",
        "@mui/material": "^5.15.12",
        "@mui/x-date-pickers": "^6.19.6",
        "@tanstack/react-query": "^5.25.0",
        "assert-never": "^1.2.1",
        "classnames": "^2.5.1",
        "comlink": "^4.4.1",
        "lodash": "^4.17.21",
        "notistack": "^3.0.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-hook-form": "^7.51.0",
        "react-hook-form-mui": "^6.8.0",
        "react-resize-detector": "^10.0.1",
        "recoil": "^0.7.7",
        "workbox-window": "^7.0.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@babel/core": "^7.24.0",
        "@babel/preset-env": "^7.24.0",
        "@babel/preset-react": "^7.23.3",
        "@babel/preset-typescript": "^7.23.3",
        "@babel/register": "^7.23.7",
        "@bubblewrap/cli": "^1.21.0",
        "@pmmmwh/react-refresh-webpack-plugin": "^0.5.11",
        "@types/lodash": "^4.14.202",
        "@types/react": "^18.2.64",
        "@types/react-dom": "^18.2.21",
        "@types/webpack-bundle-analyzer": "^4.7.0",
        "@typescript-eslint/eslint-plugin": "^7.1.1",
        "@typescript-eslint/parser": "^7.1.1",
        "@wasm-tool/wasm-pack-plugin": "1.7.0",
        "babel-loader": "^9.1.3",
        "copy-webpack-plugin": "^12.0.2",
        "css-loader": "^6.10.0",
        "csstype": "^3.1.3",
        "eslint": "^8.57.0",
        "eslint-plugin-react": "^7.34.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "favicons": "^7.1.5",
        "favicons-webpack-plugin": "^6.0.1",
        "fork-ts-checker-webpack-plugin": "^9.0.2",
        "html-webpack-plugin": "^5.6.0",
        "prettier": "^3.2.5",
        "react-refresh": "^0.14.0",
        "style-loader": "^3.3.4",
        "type-fest": "^4.12.0",
        "typescript": "^5.4.2",
        "webpack": "^5.90.3",
        "webpack-bundle-analyzer": "^4.10.1",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^5.0.2",
        "webpack-pwa-manifest": "^4.3.0",
        "workbox-webpack-plugin": "^7.0.0",
        "worker-plugin": "^5.0.1"
    },
    "overrides": {
        "@pmmmwh/react-refresh-webpack-plugin": {
            "webpack-dev-server": "^5.0.2"
        }
    }
}
