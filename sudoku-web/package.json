{
    "author": "Mathias Lengler <mathias@lengler.dev>",
    "name": "sudoku-web",
    "version": "0.2.0",
    "type": "module",
    "license": "MIT",
    "repository": "https://github.com/MathiasLengler/sudoku",
    "engines": {
        "node": "22"
    },
    "scripts": {
        "dev": "vite",
        "dev:profile": "vite --mode profile",
        "build": "vite build",
        "build:dev": "vite build --mode development",
        "build:visualize": "vite-bundle-visualizer",
        "preview": "vite preview",
        "test": "vitest",
        "test:bench": "vitest bench",
        "lint": "npm run lint:tsc && npm run lint:eslint && npm run lint:prettier",
        "lint:tsc": "tsc -b",
        "lint:tsc:watch": "npm run lint:tsc -- --watch",
        "lint:eslint": "eslint . --max-warnings 0",
        "lint:eslint:fix": "eslint . --fix",
        "lint:prettier": "prettier --check .",
        "lint:prettier:fix": "prettier --write .",
        "bubblewrap:merge": "cd ../sudoku-bubblewrap && bubblewrap merge",
        "bubblewrap:update": "cd ../sudoku-bubblewrap && bubblewrap update --appVersionName=\"1\"",
        "bubblewrap:build": "cd ../sudoku-bubblewrap && bubblewrap build",
        "docker:build": "docker build -t sudoku-web .",
        "docker:run": "docker run -it --rm -p 8080:80 sudoku-web",
        "docker:dev": "npm run build && npm run docker:build && npm run docker:run"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource-variable/inconsolata": "^5.2.6",
        "@fontsource-variable/roboto-flex": "^5.2.6",
        "@hookform/resolvers": "^5.2.1",
        "@mui/icons-material": "^7.3.1",
        "@mui/lab": "^7.0.0-beta.16",
        "@mui/material": "^7.3.1",
        "@mui/x-date-pickers": "^8.11.0",
        "@tanstack/react-query": "^5.85.6",
        "@toolpad/core": "^0.16.0",
        "@vitejs/plugin-react": "^5.0.2",
        "assert-never": "^1.4.0",
        "classnames": "^2.5.1",
        "comlink": "^4.4.2",
        "es-toolkit": "^1.41.0",
        "jotai": "^2.13.1",
        "jotai-devtools": "^0.12.0",
        "jotai-eager": "^0.2.3",
        "lodash-es": "^4.17.21",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-error-boundary": "^6.0.0",
        "react-hook-form": "^7.62.0",
        "react-hook-form-mui": "^8.0.0",
        "react-resize-detector": "^12.3.0",
        "react-virtualized-auto-sizer": "^1.0.26",
        "react-window": "^2.0.2",
        "workbox-window": "^7.3.0",
        "zod": "^4.1.5"
    },
    "devDependencies": {
        "@bubblewrap/cli": "^1.23.0",
        "@eslint/js": "^9.34.0",
        "@optimize-lodash/rollup-plugin": "^5.0.2",
        "@tsconfig/strictest": "^2.0.5",
        "@types/lodash-es": "^4.17.12",
        "@types/react": "^19.1.12",
        "@types/react-dom": "^19.1.9",
        "@types/react-window": "^1.8.8",
        "@vite-pwa/assets-generator": "^1.0.0",
        "@vitest/browser-playwright": "^4.0.9",
        "@wasm-tool/wasm-pack-plugin": "1.7.0",
        "csstype": "^3.1.3",
        "eslint": "^9.34.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
        "globals": "^16.3.0",
        "prettier": "^3.6.2",
        "type-fest": "^4.41.0",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.41.0",
        "vite": "^7.1.4",
        "vite-bundle-visualizer": "^1.2.1",
        "vite-plugin-pwa": "^1.0.3",
        "vite-plugin-wasm": "^3.5.0",
        "vitest": "^4.0.9",
        "vitest-browser-react": "^2.0.2"
    }
}
