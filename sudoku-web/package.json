{
    "author": "Mathias Lengler <mathias@lengler.dev>",
    "name": "sudoku-web",
    "version": "0.2.0",
    "type": "module",
    "license": "MIT",
    "repository": "https://github.com/MathiasLengler/sudoku",
    "engines": {
        "node": "22"
    },
    "scripts": {
        "dev": "vite",
        "dev:profile": "vite --mode profile",
        "build": "vite build",
        "build:dev": "vite build --mode development",
        "build:visualize": "vite-bundle-visualizer",
        "preview": "vite preview",
        "test": "vitest",
        "test:bench": "vitest bench",
        "test:types": "vitest --project typecheck",
        "lint": "npm run lint:tsc && npm run lint:eslint && npm run lint:prettier",
        "lint:tsc": "tsgo -b",
        "lint:tsc:watch": "npm run lint:tsc -- --watch",
        "lint:eslint": "eslint . --max-warnings 0",
        "lint:eslint:fix": "eslint . --fix",
        "lint:prettier": "prettier --check .",
        "lint:prettier:fix": "prettier --write .",
        "bubblewrap:merge": "cd ../sudoku-bubblewrap && bubblewrap merge",
        "bubblewrap:update": "cd ../sudoku-bubblewrap && bubblewrap update --appVersionName=\"1\"",
        "bubblewrap:build": "cd ../sudoku-bubblewrap && bubblewrap build",
        "docker:build": "docker build -t docker-registry.lengler.dev/sudoku:local .",
        "docker:run": "docker run -it --rm -p 8080:80 docker-registry.lengler.dev/sudoku:local",
        "docker:dev": "npm run build && npm run docker:build && npm run docker:run"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource-variable/inconsolata": "^5.2.8",
        "@fontsource-variable/roboto-flex": "^5.2.8",
        "@hookform/resolvers": "^5.2.2",
        "@mui/icons-material": "^7.3.7",
        "@mui/lab": "^7.0.1-beta.21",
        "@mui/material": "^7.3.7",
        "@mui/x-date-pickers": "^8.26.0",
        "@tanstack/react-query": "^5.90.20",
        "@toolpad/core": "^0.16.0",
        "@vitejs/plugin-react": "^5.1.2",
        "assert-never": "^1.4.0",
        "classnames": "^2.5.1",
        "comlink": "^4.4.2",
        "es-toolkit": "^1.44.0",
        "jotai": "^2.17.0",
        "jotai-eager": "^0.2.4",
        "react": "^19.0.4",
        "react-dom": "^19.0.4",
        "react-error-boundary": "^6.1.0",
        "react-hook-form": "^7.71.1",
        "react-hook-form-mui": "^8.2.0",
        "react-resize-detector": "^12.3.0",
        "react-window": "^2.2.6",
        "sudoku-wasm": "file:../sudoku-wasm/pkg",
        "workbox-window": "^7.4.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@bubblewrap/cli": "^1.24.1",
        "@eslint/js": "^9.39.2",
        "@tsconfig/strictest": "^2.0.8",
        "@types/react": "^19.2.10",
        "@types/react-dom": "^19.2.3",
        "@types/react-window": "^1.8.8",
        "@typescript/native-preview": "^7.0.0-dev.20260131.1",
        "@vite-pwa/assets-generator": "^1.0.2",
        "@vitest/browser-playwright": "^4.0.18",
        "@wasm-tool/wasm-pack-plugin": "1.7.0",
        "csstype": "^3.2.3",
        "eslint": "^9.39.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.26",
        "eslint-plugin-zod-x": "^1.13.2",
        "globals": "^17.2.0",
        "prettier": "^3.8.1",
        "type-fest": "^5.4.3",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.54.0",
        "vite": "^7.3.1",
        "vite-bundle-visualizer": "^1.2.1",
        "vite-plugin-pwa": "^1.2.0",
        "vite-plugin-wasm": "^3.5.0",
        "vitest": "^4.0.18",
        "vitest-browser-react": "^2.0.5"
    }
}
