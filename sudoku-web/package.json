{
    "author": "Mathias Lengler <mathias@lengler.dev>",
    "name": "sudoku-web",
    "version": "0.2.0",
    "type": "module",
    "license": "MIT",
    "repository": "https://github.com/MathiasLengler/sudoku",
    "engines": {
        "node": "22"
    },
    "scripts": {
        "dev": "vite",
        "dev:profile": "vite --mode profile",
        "build": "vite build",
        "build:dev": "vite build --mode development",
        "build:debug-sw": "vite build --mode debug-sw",
        "build:visualize": "vite-bundle-visualizer",
        "lint": "npm run lint:tsc && npm run lint:eslint && npm run lint:prettier",
        "lint:tsc": "tsc -b",
        "lint:tsc:watch": "npm run lint:tsc -- --watch",
        "lint:eslint": "eslint . --max-warnings 0",
        "lint:eslint:fix": "eslint . --fix",
        "lint:prettier": "prettier --check .",
        "lint:prettier:fix": "prettier --write .",
        "serve": "npx serve -l 8080 -c ../serve.json dist",
        "bubblewrap:merge": "cd ../sudoku-bubblewrap && bubblewrap merge",
        "bubblewrap:update": "cd ../sudoku-bubblewrap && bubblewrap update",
        "bubblewrap:build": "cd ../sudoku-bubblewrap && bubblewrap build",
        "docker:build": "docker build -t sudoku-web .",
        "docker:run": "docker run -it --rm -p 8080:80 sudoku-web",
        "docker:dev": "npm run build && npm run docker:build && npm run docker:run"
    },
    "dependencies": {
        "@fontsource-variable/inconsolata": "^5.1.0",
        "@fontsource-variable/roboto-flex": "^5.1.0",
        "@hookform/resolvers": "^3.9.1",
        "@mui/icons-material": "^6.3.0",
        "@mui/lab": "^6.0.0-beta.21",
        "@mui/material": "^6.3.0",
        "@mui/material-pigment-css": "^6.3.0",
        "@mui/x-date-pickers": "^7.23.3",
        "@pigment-css/react": "^0.0.28",
        "@tanstack/react-query": "^5.62.11",
        "@toolpad/core": "^0.11.0",
        "assert-never": "^1.4.0",
        "classnames": "^2.5.1",
        "comlink": "^4.4.2",
        "lodash": "^4.17.21",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-error-boundary": "^5.0.0",
        "react-hook-form": "^7.54.2",
        "react-hook-form-mui": "^7.4.1",
        "react-resize-detector": "^12.0.1",
        "react-virtualized-auto-sizer": "^1.0.25",
        "react-window": "^1.8.11",
        "recoil": "^0.7.7",
        "workbox-window": "^7.3.0",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@bubblewrap/cli": "^1.22.2",
        "@eslint/js": "^9.17.0",
        "@pigment-css/vite-plugin": "^0.0.29",
        "@tsconfig/strictest": "^2.0.5",
        "@types/lodash": "^4.17.13",
        "@types/react": "^19.0.2",
        "@types/react-dom": "^19.0.2",
        "@types/react-window": "^1.8.8",
        "@vitejs/plugin-react-swc": "^3.7.2",
        "@wasm-tool/wasm-pack-plugin": "1.7.0",
        "csstype": "^3.1.3",
        "eslint": "^9.17.0",
        "eslint-plugin-react": "^7.37.3",
        "eslint-plugin-react-hooks": "^5.1.0",
        "eslint-plugin-react-refresh": "^0.4.16",
        "favicons": "^7.2.0",
        "globals": "^15.14.0",
        "prettier": "^3.4.2",
        "type-fest": "^4.31.0",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.18.2",
        "vite": "^6.0.6",
        "vite-plugin-wasm": "^3.4.1"
    },
    "overrides": {
        "react": "^19.0.0",
        "vite": "^6.0.6"
    }
}
