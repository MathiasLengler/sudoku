{
    "author": "Mathias Lengler <mathias@lengler.dev>",
    "name": "sudoku-web",
    "version": "0.2.0",
    "license": "MIT",
    "repository": "https://github.com/MathiasLengler/sudoku",
    "scripts": {
        "start": "webpack serve --mode development",
        "start:profiling": "webpack serve --mode production --env reactProfiling=true",
        "build": "webpack --mode production",
        "build:debugSW": "webpack --mode development --env debugSW=true",
        "build:analyze": "webpack --mode production --env bundleAnalyzer=true",
        "lint": "npm run lint:tsc && npm run lint:eslint",
        "lint:tsc": "tsc",
        "lint:eslint": "eslint src/** webpack.config.ts",
        "serve": "npx serve -l 8080 dist",
        "bubblewrap:merge": "cd ../sudoku-bubblewrap && bubblewrap merge",
        "bubblewrap:update": "cd ../sudoku-bubblewrap && bubblewrap update",
        "bubblewrap:build": "cd ../sudoku-bubblewrap && bubblewrap build"
    },
    "engines": {
        "node": "18"
    },
    "devDependencies": {
        "@babel/core": "^7.22.1",
        "@babel/preset-env": "^7.22.2",
        "@babel/preset-react": "^7.22.3",
        "@babel/preset-typescript": "^7.21.5",
        "@babel/register": "^7.21.0",
        "@bubblewrap/cli": "^1.20.0",
        "@pmmmwh/react-refresh-webpack-plugin": "^0.5.10",
        "@types/lodash": "^4.14.195",
        "@types/react": "^18.2.7",
        "@types/react-dom": "^18.2.4",
        "@types/webpack-bundle-analyzer": "^4.6.0",
        "@typescript-eslint/eslint-plugin": "^5.59.7",
        "@typescript-eslint/parser": "^5.59.7",
        "@wasm-tool/wasm-pack-plugin": "1.7.0",
        "babel-loader": "^9.1.2",
        "copy-webpack-plugin": "^11.0.0",
        "css-loader": "^6.8.1",
        "csstype": "^3.1.2",
        "eslint": "^8.41.0",
        "eslint-plugin-react": "^7.32.2",
        "eslint-plugin-react-hooks": "^4.6.0",
        "favicons": "^7.1.2",
        "favicons-webpack-plugin": "^6.0.0",
        "fork-ts-checker-webpack-plugin": "^8.0.0",
        "html-webpack-plugin": "^5.5.1",
        "prettier": "^2.8.8",
        "react-refresh": "^0.14.0",
        "style-loader": "^3.3.3",
        "type-fest": "^3.11.0",
        "typescript": "^5.0.4",
        "webpack": "^5.84.1",
        "webpack-bundle-analyzer": "^4.8.0",
        "webpack-cli": "^5.1.1",
        "webpack-dev-server": "^4.15.0",
        "webpack-pwa-manifest": "^4.3.0",
        "workbox-webpack-plugin": "^6.6.0",
        "worker-plugin": "^5.0.1"
    },
    "dependencies": {
        "@babel/runtime": "^7.22.3",
        "@emotion/react": "^11.11.0",
        "@emotion/styled": "^11.11.0",
        "@fontsource-variable/inconsolata": "^5.0.2",
        "@fontsource-variable/roboto-flex": "^5.0.2",
        "@hookform/resolvers": "^3.1.0",
        "@mui/icons-material": "^5.11.16",
        "@mui/lab": "^5.0.0-alpha.131",
        "@mui/material": "^5.13.2",
        "@mui/x-date-pickers": "^6.5.0",
        "assert-never": "^1.2.1",
        "classnames": "^2.3.2",
        "comlink": "^4.4.1",
        "lodash": "^4.17.21",
        "notistack": "^3.0.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-hook-form": "^7.44.1",
        "react-hook-form-mui": "^6.1.1",
        "react-resize-detector": "^9.1.0",
        "recoil": "^0.7.7",
        "workbox-window": "^6.6.0",
        "zod": "^3.21.4"
    }
}
