{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "composite": true,
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.bindings.tsbuildinfo",
        "target": "ESNext",
        "useDefineForClassFields": true,
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "jsx": "react-jsx",
        "skipLibCheck": false,
        "types": []
    },
    "include": [
        //
        "../sudoku-wasm/pkg/*.ts",
        "../sudoku-rs/bindings",
        "src/app/state/world/schema.ts",
        "src/app/utils/serializedData.ts",
        "src/typeUtils.ts",
        "src/types.ts",
        "src/**/*.d.ts"
    ]
}
